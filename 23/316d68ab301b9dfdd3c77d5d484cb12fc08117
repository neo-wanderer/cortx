          "text": "# Implementation Plan: Sort Feature for Query Command\n\n## Overview\n\nAdd sorting capability to the `query` command with `--sort-by` flag supporting per-field order specification. Null values sort to the end. Also add support for field names with spaces (quoted identifiers) in both queries and sort specifications.\n\n## Requirements\n\n| Requirement | Decision |\n|-------------|----------|\n| Command integration | Add to existing `query` command |\n| Sort fields | Support single and multiple fields (comma-separated) |\n| Sort order | Per-field order via `field:order` syntax (e.g., `priority:asc,due:desc`) |\n| Null handling | Missing/null values sort to end regardless of order |\n| Value comparison | Leverage existing `Value::partial_cmp` impl |\n| Quoted field names | Support `\"Due By\"` syntax in both queries and sort (for field names with spaces) |\n\n## CLI Interface\n\n```bash\n# Single field, ascending (default)\ncortx query 'status != \"done\"' --sort-by due\n\n# Single field, descending\ncortx query 'status != \"done\"' --sort-by due:desc\n\n# Multiple fields with per-field order\ncortx query 'type = \"task\"' --sort-by priority:asc,due:desc\n\n# Field names with spaces (quoted)\ncortx query '\"Due By\" < today' --sort-by '\"Due By\":desc'\n\n# JSON output (existing)\ncortx query 'status = \"open\"' --sort-by due:desc --format json\n```\n\n**Syntax:** `--sort-by field[:order][,field[:order]...]`\n- `:order` is optional, defaults to `asc`\n- Valid orders: `asc` or `desc`\n- Field names with spaces must be quoted: `\"Due By\"`\n- Quoted fields in sort spec: `'\"Due By\":asc'` (outer quotes for shell)\n\n## Implementation Steps\n\n### Step 1: Add quoted field support to query tokenizer (`src/query/parser.rs`)\n\nUpdate the tokenizer to handle quoted field names with spaces:\n\n```rust\n// In tokenize() function, add after the string literal handling (~line 76-87):\n'\"' => {\n    i += 1;\n    let start = i;\n    while i < chars.len() && chars[i] != '\"' {\n        i += 1;\n    }\n    if i >= chars.len() {\n        return Err(CortxError::QueryParse(\"unclosed string literal\".into()));\n    }\n    let s: String = chars[start..i].iter().collect();\n    tokens.push(Token::StringLit(s));\n    i += 1;\n}\n```\n\nThen update `parse_primary()` to accept `Token::StringLit` as field names:\n\n```rust\n// In parse_primary(), around line 201-208, change:\nlet field = match &tokens[*pos] {\n    Token::Ident(s) => s.clone(),\n    Token::StringLit(s) => s.clone(),  // Add this line for quoted field names\n    other => {\n        return Err(CortxError::QueryParse(format!(\n            \"expected field name, got '{other}'\"\n        )));\n    }\n};\n```\n\n### Step 2: Update QueryArgs in `src/cli/query_cmd.rs`\n\n```rust\n#[derive(Args)]\npub struct QueryArgs {\n    pub expression: String,\n\n    #[arg(long, default_value = \"text\")]\n    pub format: String,\n\n    /// Sort by field(s). Format: field[:order][,field[:order]...]\n    /// Order defaults to 'asc'. Example: --sort-by priority:asc,due:desc\n    /// Quoted fields for spaces: --sort-by '\"Due By\":desc'\n    #[arg(long)]\n    pub sort_by: Option<String>,\n}\n```\n\n### Step 3: Create SortSpec parser with quoted field support\n\nParse `--sort-by` argument into a list of (field, descending) pairs, handling quoted field names:\n\n```rust\nstruct SortSpec {\n    field: String,\n    descending: bool,\n}\n\nfn parse_sort_by(spec: &str) -> Result<Vec<SortSpec>, CortxError> {\n    let mut result = Vec::new();\n    let chars: Vec<char> = spec.chars().collect();\n    let mut i = 0;\n\n    while i < chars.len() {\n        // Parse field name (possibly quoted)\n        let field = if chars[i] == '\"' {\n            i += 1;\n            let start = i;\n            while i < chars.len() && chars[i] != '\"' {\n                i += 1;\n            }\n            if i >= chars.len() {\n                return Err(CortxError::Parse(\"unclosed quoted field name\".into()));\n            }\n            let f: String = chars[start..i].iter().collect();\n            i += 1; // skip closing quote\n            f\n        } else {\n            let start = i;\n            while i < chars.len() && chars[i] != ':' && chars[i] != ',' {\n                i += 1;\n            }\n            chars[start..i].iter().collect()\n        };\n\n        // Skip whitespace\n        while i < chars.len() && chars[i].is_whitespace() {\n            i += 1;\n        }\n\n        // Parse optional :order\n        let descending = if i < chars.len() && chars[i] == ':' {\n            i += 1;\n            let start = i;\n            while i < chars.len() && chars[i] != ',' {\n                i += 1;\n            }\n            let order: String = chars[start..i].iter().collect();\n            match order.trim() {\n                \"desc\" => true,\n                \"asc\" => false,\n                _ => return Err(CortxError::Parse(format!(\"invalid order '{order}', expected 'asc' or 'desc'\"))),\n            }\n        } else {\n            false\n        };\n\n        result.push(SortSpec { field: field.trim().to_string(), descending });\n\n        // Skip comma separator\n        if i < chars.len() && chars[i] == ',' {\n            i += 1;\n        }\n    }\n\n    Ok(result)\n}\n```\n\n### Step 4: Implement sort_entities function\n\n```rust\nfn sort_entities(entities: &mut [&Entity], specs: &[SortSpec]) {\n    entities.sort_by(|a, b| {\n        for spec in specs {\n            let cmp = compare_values(\n                a.get(&spec.field),\n                b.get(&spec.field),\n                spec.descending\n            );\n            if cmp != Ordering::Equal {\n                return cmp;\n            }\n        }\n        Ordering::Equal\n    });\n}\n\nfn compare_values(a: Option<&Value>, b: Option<&Value>, descending: bool) -> Ordering {\n    match (a, b) {\n        (Some(av), Some(bv)) => {\n            let cmp = av.partial_cmp(bv).unwrap_or(Ordering::Equal);\n            if descending { cmp.reverse() } else { cmp }\n        }\n        (None, None) => Ordering::Equal,\n        (Some(_), None) => Ordering::Less,  // nulls to end\n        (None, Some(_)) => Ordering::Greater, // nulls to end\n    }\n}\n```\n\n### Step 5: Update run() function\n\n```rust\nlet mut matches: Vec<_> = all.iter().filter(|e| evaluate(&expr, e)).collect();\n\nif let Some(sort_by) = &args.sort_by {\n    let specs = parse_sort_by(sort_by)?;\n    sort_entities(&mut matches, &specs);\n}\n```\n\n### Step 6: Add tests in `tests/cli_integration_test.rs`\n\n**Sort tests:**\n- Single field ascending (default)\n- Single field with explicit `:desc`\n- Multi-field with mixed orders (`priority:asc,due:desc`)\n- Null handling (entities without the field)\n- Sort by date field\n- Sort by numeric field\n- Invalid order string error handling\n\n**Quoted field name tests:**\n- Query with quoted field: `'\"Due By\" < today'`\n- Sort with quoted field: `--sort-by '\"Due By\":desc'`\n- Mixed quoted and unquoted: `--sort-by '\"Due By\",priority'`\n\n## Files to Modify\n\n| File | Change |\n|------|--------|\n| `src/query/parser.rs` | Accept `Token::StringLit` as field names in `parse_primary()` |\n| `src/cli/query_cmd.rs` | Add args, implement `parse_sort_by` (with quoted field support) and `sort_entities` |\n| `tests/cli_integration_test.rs` | Add sort and quoted field name tests |\n| `benches/query_bench.rs` | Add sort benchmarks |\n\n## Benchmarks\n\nAdd sorting benchmarks to `benches/query_bench.rs` following the existing pattern:\n\n```rust\n// Add to bench_query_scan function after distinct_tags benchmark\n\n// Single field sort (ascending)\nlet simple_expr = parse_query(r#\"type = \"task\"\"#).unwrap();\ngroup.bench_with_input(BenchmarkId::new(\"sort_single_field\", size), &size, |b, _| {\n    b.iter(|| {\n        let all = repo.list_all(&registry).unwrap();\n        let mut matches: Vec<_> = all.iter().filter(|e| evaluate(&simple_expr, e)).collect();\n        sort_entities(&mut matches, &[SortSpec { field: \"due\".into(), descending: false }]);\n        assert!(!matches.is_empty());\n    });\n});\n\n// Single field sort (descending)\ngroup.bench_with_input(BenchmarkId::new(\"sort_single_desc\", size), &size, |b, _| {\n    b.iter(|| {\n        let all = repo.list_all(&registry).unwrap();\n        let mut matches: Vec<_> = all.iter().filter(|e| evaluate(&simple_expr, e)).collect();\n        sort_entities(&mut matches, &[SortSpec { field: \"due\".into(), descending: true }]);\n        assert!(!matches.is_empty());\n    });\n});\n\n// Multi-field sort\ngroup.bench_with_input(BenchmarkId::new(\"sort_multi_field\", size), &size, |b, _| {\n    b.iter(|| {\n        let all = repo.list_all(&registry).unwrap();\n        let mut matches: Vec<_> = all.iter().filter(|e| evaluate(&simple_expr, e)).collect();\n        sort_entities(&mut matches, &[\n            SortSpec { field: \"status\".into(), descending: false },\n            SortSpec { field: \"due\".into(), descending: true },\n        ]);\n        assert!(!matches.is_empty());\n    });\n});\n```\n\nNote: `SortSpec` and `sort_entities` will need to be exported from `cli/query_cmd.rs` or moved to a shared module for benchmark access.\n\n## Testing Commands\n\n```bash\n# Create test entities\ncortx create task --title \"Task A\" --set due=2026-04-05 --set priority=1\ncortx create task --title \"Task B\" --set due=2026-04-03 --set priority=2\ncortx create task --title \"Task C\" --set priority=1  # no due date\n\n# Test sorting\ncortx query 'type = \"task\"' --sort-by due\ncortx query 'type = \"task\"' --sort-by due:desc\ncortx query 'type = \"task\"' --sort-by priority:asc,due:desc\n\n# Create entity with space in field name (via direct file edit or custom field)\n# Then test quoted field names:\ncortx query '\"Due By\" < today' --sort-by '\"Due By\":asc'\n```",
