Windows constraint)\n    loop {\n        if result.ends_with('.') {\n            result.pop();\n            while result.ends_with(' ') {\n                result.pop();\n            }\n        } else {\n            break;\n        }\n    }\n\n    result\n}\n\n/// Convert a title string to a URL-safe slug.",
