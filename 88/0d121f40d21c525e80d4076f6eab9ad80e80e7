            "content": "\n## Phase 4: CLI Layer\n\n### Task 11: Config module and CLI skeleton\n\n**Files:**\n- Create: `src/config.rs`\n- Create: `src/cli/mod.rs`\n- Create: `src/cli/create.rs`\n- Create: `src/cli/show.rs`\n- Create: `src/cli/update.rs`\n- Create: `src/cli/archive.rs`\n- Create: `src/cli/delete.rs`\n- Create: `src/cli/query_cmd.rs`\n- Create: `src/cli/meta.rs`\n- Create: `src/cli/note.rs`\n- Create: `src/cli/doctor.rs`\n- Modify: `src/main.rs`\n\n- [ ] **Step 1: Implement config module**\n\nCreate `src/config.rs`:\n\n```rust\nuse std::path::{Path, PathBuf};\nuse crate::error::{CortxError, Result};\nuse crate::schema::registry::TypeRegistry;\n\npub struct Config {\n    pub vault_path: PathBuf,\n    pub registry: TypeRegistry,\n}\n\nimpl Config {\n    pub fn load(vault_path: Option<&str>) -> Result<Self> {\n        // Resolve vault path: CLI arg > CORTX_VAULT env > current dir\n        let vault_path = if let Some(p) = vault_path {\n            PathBuf::from(p)\n        } else if let Ok(p) = std::env::var(\"CORTX_VAULT\") {\n            PathBuf::from(p)\n        } else {\n            std::env::current_dir()?\n        };\n\n        if !vault_path.exists() {\n            return Err(CortxError::Storage(format!(\n                \"vault path does not exist: {}\",\n                vault_path.display()\n            )));\n        }\n\n        // Look for types.yaml in vault root, then next to the binary\n        let types_path = find_types_yaml(&vault_path)?;\n        let registry = TypeRegistry::from_yaml_file(&types_path)?;\n\n        Ok(Config {\n            vault_path,\n            registry,\n        })\n    }\n}\n\nfn find_types_yaml(vault_path: &Path) -> Result<PathBuf> {\n    // Check vault root\n    let in_vault = vault_path.join(\"types.yaml\");\n    if in_vault.exists() {\n        return Ok(in_vault);\n    }\n\n    // Check current working directory\n    let in_cwd = PathBuf::from(\"types.yaml\");\n    if in_cwd.exists() {\n        return Ok(in_cwd);\n    }\n\n    Err(CortxError::Schema(\n        \"types.yaml not found in vault directory or current directory\".into(),\n    ))\n}\n```\n\n- [ ] **Step 2: Create CLI skeleton with clap**\n\nCreate `src/cli/mod.rs`:\n\n```rust\npub mod create;\npub mod show;\npub mod update;\npub mod archive;\npub mod delete;\npub mod query_cmd;\npub mod meta;\npub mod note;\npub mod doctor;\n\nuse clap::{Parser, Subcommand};\n\n#[derive(Parser)]\n#[command(name = \"cortx\", version, about = \"Second Brain CLI for agents and humans\")]\npub struct Cli {\n    /// Path to the vault directory\n    #[arg(long, global = true)]\n    pub vault: Option<String>,\n\n    #[command(subcommand)]\n    pub command: Commands,\n}\n\n#[derive(Subcommand)]\npub enum Commands {\n    /// Create a new entity (e.g., cortx create task --title \"...\")\n    Create(create::CreateArgs),\n    /// Show an entity by ID\n    Show(show::ShowArgs),\n    /// Update entity fields\n    Update(update::UpdateArgs),\n    /// Archive an entity (soft delete)\n    Archive(archive::ArchiveArgs),\n    /// Delete an entity\n    Delete(delete::DeleteArgs),\n    /// Run a query against the vault\n    Query(query_cmd::QueryArgs),\n    /// Metadata aggregations (distinct, count-by)\n    Meta(meta::MetaArgs),\n    /// Note editing commands (headings, insert, replace, read-lines)\n    Note(note::NoteArgs),\n    /// Doctor / lint commands (validate, links)\n    Doctor(doctor::DoctorArgs),\n}\n```\n\n- [ ] **Step 3: Implement create command**\n\nThe `create` command takes the entity type as a positional argument — `cortx create task --title \"...\"`. The type is resolved from the TypeRegistry at runtime, so adding new types requires only a `types.yaml` change.\n\nCreate `src/cli/create.rs`:\n\n```rust\nuse clap::Args;\nuse crate::config::Config;\nuse crate::error::Result;\nuse crate::storage::markdown::MarkdownRepository;\nuse crate::storage::Repository;\nuse crate::value::Value;\nuse std::collections::HashMap;\n\n#[derive(Args)]\npub struct CreateArgs {\n    /// Entity type (resolved from types.yaml, e.g. task, project, person)\n    pub entity_type: String,\n\n    /// Entity ID (auto-generated if not provided)\n    #[arg(long)]\n    pub id: Option<String>,\n\n    /// Entity title (for types with a title field)\n    #[arg(long)]\n    pub title: Option<String>,\n\n    /// Name (for types with a name field, e.g. person, company)\n    #[arg(long)]\n    pub name: Option<String>,\n\n    /// Tags (comma-separated)\n    #[arg(long)]\n    pub tags: Option<String>,\n\n    /// Additional key=value fields\n    #[arg(long = \"set\", num_args = 1)]\n    pub fields: Vec<String>,\n}\n\npub fn run(args: &CreateArgs, config: &Config) -> Result<()> {\n    let repo = MarkdownRepository::new(config.vault_path.clone());\n\n    let mut fm = HashMap::new();\n\n    // Generate or use provided ID\n    let id = args.id.clone().unwrap_or_else(|| {\n        let today = chrono::Local::now().format(\"%Y%m%d\");\n        let short = &uuid::Uuid::new_v4().to_string()[..8];\n        format!(\"{}-{today}-{short}\", args.entity_type)\n    });\n\n    fm.insert(\"id\".into(), Value::String(id.clone()));\n    fm.insert(\"type\".into(), Value::String(args.entity_type.clone()));\n\n    if let Some(title) = &args.title {\n        fm.insert(\"title\".into(), Value::String(title.clone()));\n    }\n    if let Some(name) = &args.name {\n        fm.insert(\"name\".into(), Value::String(name.clone()));\n    }\n\n    // Set default status if the type schema has a status field\n    if let Some(type_def) = config.registry.get(&args.entity_type) {\n        if type_def.fields.contains_key(\"status\")\n            && !args.fields.iter().any(|f| f.starts_with(\"status=\"))\n        {\n            fm.insert(\"status\".into(), Value::String(\"open\".into()));\n        }\n    }\n\n    if let Some(tags) = &args.tags {\n        let tag_list: Vec<Value> = tags\n            .split(',')\n            .map(|t| Value::String(t.trim().to_string()))\n            .collect();\n        fm.insert(\"tags\".into(), Value::Array(tag_list));\n    } else {\n        fm.insert(\"tags\".into(), Value::Array(vec![]));\n    }\n\n    // Parse --set key=value pairs\n    for kv in &args.fields {\n        if let Some((k, v)) = kv.split_once('=') {\n            let value = parse_cli_value(v);\n            fm.insert(k.to_string(), value);\n        }\n    }\n\n    let today = chrono::Local::now().date_naive();\n    fm.insert(\"created_at\".into(), Value::Date(today));\n    fm.insert(\"updated_at\".into(), Value::Date(today));\n\n    let entity = repo.create(fm, \"\", &config.registry)?;\n    println!(\"Created {} ({})\", entity.id, entity.entity_type);\n    if let Some(path) = &entity.file_path {\n        println!(\"  File: {}\", path.display());\n    }\n\n    Ok(())\n}\n\n/// Parse a CLI value string into a Value.\n/// Handles dates (YYYY-MM-DD), wiki links ([[id]]), arrays ([a,b,c]), and plain strings.\nfn parse_cli_value(v: &str) -> Value {\n    if let Some(date_val) = Value::parse_as_date(v) {\n        return date_val;\n    }\n    if v.starts_with('[') && v.ends_with(']') {\n        let inner = &v[1..v.len() - 1];\n        let arr: Vec<Value> = inner\n            .split(',')\n            .map(|s| Value::String(s.trim().trim_matches('\"').to_string()))\n            .collect();\n        return Value::Array(arr);\n    }\n    Value::String(v.to_string())\n}\n```\n\n- [ ] **Step 4: Implement show command**\n\nCreate `src/cli/show.rs`:\n\n```rust\nuse clap::Args;\nuse crate::config::Config;\nuse crate::error::Result;\nuse crate::storage::markdown::MarkdownRepository;\nuse crate::storage::Repository;\n\n#[derive(Args)]\npub struct ShowArgs {\n    /// Entity ID\n    pub id: String,\n}\n\npub fn run(args: &ShowArgs, config: &Config) -> Result<()> {\n    let repo = MarkdownRepository::new(config.vault_path.clone());\n    let entity = repo.get_by_id(&args.id, &config.registry)?;\n\n    println!(\"ID: {}\", entity.id);\n    println!(\"Type: {}\", 