ey == \"title\" || key == \"name\" {\n            continue;\n        }\n        println!(\"  {key}: {}\", entity.frontmatter[key]);\n    }\n\n    if !entity.body.trim().is_empty() {\n        println!(\"\\n{}\", entity.body);\n    }\n\n    Ok(())\n}\n```\n\nCreate `src/cli/update.rs`:\n\n```rust\nuse clap::Args;\nuse crate::config::Config;\nuse crate::error::Result;\nuse crate::storage::markdown::MarkdownRepository;\nuse crate::storage::Repository;\nuse crate::value::Value;\nuse std::collections::HashMap;\n\n#[derive(Args)]\npub struct UpdateArgs {\n    /// Entity ID\n    pub id: String,\n\n    /// Field updates as key=value pairs\n    #[arg(long = \"set\", num_args = 1, required = true)]\n    pub updates: Vec<String>,\n}\n\npub fn run(args: &UpdateArgs, config: &Config) -> Result<()> {\n    let repo = MarkdownRepository::new(config.vault_path.clone());\n\n    let mut updates = HashMap::new();\n    for kv in &args.updates {\n        if let Some((k, v)) = kv.split_once('=') {\n            if let Some(date_val) = Value::parse_as_date(v) {\n                updates.insert(k.to_string(), date_val);\n            } else if v.starts_with('[') {\n                // Simple array parsing: [a,b,c]\n                let inner = v.trim_start_matches('[').trim_end_matches(']');\n                let arr: Vec<Value> = inner\n                    .split(',')\n                    .map(|s| Value::String(s.trim().trim_matches('\"').to_string()))\n                    .collect();\n                updates.insert(k.to_string(), Value::Array(arr));\n            } else {\n                updates.insert(k.to_string(), Value::String(v.to_string()));\n            }\n        }\n    }\n\n    let entity = repo.update(&args.id, updates, &config.registry)?;\n    println!(\"Updated {}\", entity.id);\n\n    Ok(())\n}\n```\n\nCreate `src/cli/archive.rs`:\n\n```rust\nuse clap::Args;\nuse crate::config::Config;\nuse crate::error::Result;\nuse crate::storage::markdown::MarkdownRepository;\nuse crate::storage::Repository;\nuse crate::value::Value;\nuse std::collections::HashMap;\n\n#[derive(Args)]\npub struct ArchiveArgs {\n    /// Entity ID\n    pub id: String,\n}\n\npub fn run(args: &ArchiveArgs, config: &Config) -> Result<()> {\n    let repo = MarkdownRepository::new(config.vault_path.clone());\n\n    let mut updates = HashMap::new();\n    updates.insert(\"status\".into(), Value::String(\"archived\".into()));\n\n    let entity = repo.update(&args.id, updates, &config.registry)?;\n    println!(\"Archived {}\", entity.id);\n\n    Ok(())\n}\n```\n\nCreate `src/cli/delete.rs`:\n\n```rust\nuse clap::Args;\nuse crate::config::Config;\nuse crate::error::Result;\nuse crate::storage::markdown::MarkdownRepository;\nuse crate::storage::Repository;\n\n#[derive(Args)]\npub struct DeleteArgs {\n    /// Entity ID\n    pub id: String,\n\n    /// Skip confirmation\n    #[arg(long)]\n    pub force: bool,\n}\n\npub fn run(args: &DeleteArgs, config: &Config) -> Result<()> {\n    let repo = MarkdownRepository::new(config.vault_path.clone());\n    repo.delete(&args.id, &config.registry)?;\n    println!(\"Deleted {}\", args.id);\n\n    Ok(())\n}\n```\n\nCreate `src/cli/query_cmd.rs`:\n\n```rust\nuse clap::Args;\nuse crate::config::Config;\nuse crate::error::Result;\nuse crate::query::evaluator::evaluate;\nuse crate::query::parser::parse_query;\nuse crate::storage::markdown::MarkdownRepository;\nuse crate::storage::Repository;\n\n#[derive(Args)]\npub struct QueryArgs {\n    /// Query expression\n    pub expression: String,\n\n    /// Output format (text or json)\n    #[arg(long, default_value = \"text\")]\n    pub format: String,\n}\n\npub fn run(args: &QueryArgs, config: &Config) -> Result<()> {\n    let expr = parse_query(&args.expression)?;\n    let repo = MarkdownRepository::new(config.vault_path.clone());\n    let all = repo.list_all(&config.registry)?;\n\n    let matches: Vec<_> = all.iter().filter(|e| evaluate(&expr, e)).collect();\n\n    if args.format == \"json\" {\n        let item