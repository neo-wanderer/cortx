ate `src/value.rs`:\n\n```rust\nuse chrono::NaiveDate;\nuse std::cmp::Ordering;\nuse std::fmt;\n\n#[derive(Debug, Clone, PartialEq)]\npub enum Value {\n    String(String),\n    Date(NaiveDate),\n    Bool(bool),\n    Number(f64),\n    Array(Vec<Value>),\n    Null,\n}\n\nimpl Value {\n    pub fn from_yaml(yaml: &serde_yaml::Value) -> Self {\n        match yaml {\n            serde_yaml::Value::String(s) => {\n                // Try parsing as date first\n                if let Some(date_val) = Self::parse_as_date(s) {\n                    return date_val;\n                }\n                Value::String(s.clone())\n            }\n            serde_yaml::Value::Bool(b) => Value::Bool(*b),\n            serde_yaml::Value::Number(n) => {\n                Value::Number(n.as_f64().unwrap_or(0.0))\n            }\n            serde_yaml::Value::Sequence(seq) => {\n                Value::Array(seq.iter().map(|v| Value::from_yaml(v)).collect())\n            }\n            serde_yaml::Value::Null => Value::Null,\n            serde_yaml::Value::Tagged(tagged) => Value::from_yaml(&tagged.value),\n            serde_yaml::Value::Mapping(_) => Value::Null,\n        }\n    }\n\n    pub fn parse_as_date(s: &str) -> Option<Value> {\n        NaiveDate::parse_from_str(s, \"%Y-%m-%d\")\n            .ok()\n            .map(Value::Date)\n    }\n\n    pub fn as_str(&self) -> Option<&str> {\n        match self {\n            Value::String(s) => Some(s),\n            _ => None,\n        }\n    }\n\n    pub fn as_date(&self) -> Option<NaiveDate> {\n        match self {\n            Value::Date(d) => Some(*d),\n            _ => None,\n        }\n    }\n\n    pub fn contains(&self, item: &Value) -> bool {\n        match self {\n            Value::Array(arr) => arr.contains(item),\n            _ => false,\n        }\n    }\n\n    pub fn to_yaml(&self) -> serde_yaml::Value {\n        match self {\n            Value::String(s) => serde_yaml::Value::String(s.clone()),\n            Value::Date(d) => s