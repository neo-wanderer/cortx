 mut fm = HashMap::new();\n\n    // Generate or use provided ID\n    let id = args.id.clone().unwrap_or_else(|| {\n        let today = chrono::Local::now().format(\"%Y%m%d\");\n        let short = &uuid::Uuid::new_v4().to_string()[..8];\n        format!(\"{}-{today}-{short}\", args.r#type)\n    });\n\n    fm.insert(\"id\".into(), Value::String(id.clone()));\n    fm.insert(\"type\".into(), Value::String(args.r#type.clone()));\n\n    if let Some(title) = &args.title {\n        fm.insert(\"title\".into(), Value::String(title.clone()));\n    }\n    if let Some(name) = &args.name {\n        fm.insert(\"name\".into(), Value::String(name.clone()));\n    }\n    if let Some(status) = &args.status {\n        fm.insert(\"status\".into(), Value::String(status.clone()));\n    } else if let Some(type_def) = config.registry.get(&args.r#type) {\n        // Default status for types that have it\n        if type_def.fields.contains_key(\"status\") {\n            fm.insert(\"status\".into(), Value::String(\"open\".into()));\n        }\n    }\n    if let Some(due) = &args.due {\n        if let Some(d) = Value::parse_as_date(due) {\n            fm.insert(\"due\".into(), d);\n        } else {\n            fm.insert(\"due\".into(), Value::String(due.clone()));\n        }\n    }\n    if let Some(scheduled) = &args.scheduled {\n        if let Some(d) = Value::parse_as_date(scheduled) {\n            fm.insert(\"scheduled\".into(), d);\n        } else {\n            fm.insert(\"scheduled\".into(), Value::String(scheduled.clone()));\n        }\n    }\n    if let Some(project) = &args.project {\n        fm.insert(\"project\".into(), Value::String(format!(\"[[{project}]]\")));\n    }\n    if let Some(area) = &args.area {\n        fm.insert(\"area\".into(), Value::String(format!(\"[[{area}]]\")));\n    }\n    if let Some(assignee) = &args.assignee {\n        fm.insert(\"assignee\".into(), Value::String(format!(\"[[{assignee}]]\")));\n    }\n    if let Some(company) = &args.company {\n        fm.insert(\"company\".into(), Value::String(format!(\"[[{company}]]\")));\n    }\n    if let Some(tags) = &args.tags {\n        let tag_list: Vec<Value> = tags\n            .split(',')\n            .map(|t| Value::String(t.trim().to_string()))\n            .collect();\n        fm.insert(\"tags\".into(), Value::Array(tag_list));\n    } else {\n        fm.insert(\"tags\".into(), Value::Array(vec![]));\n    }\n\n    // Extra key=value pairs\n    for kv in &args.extra {\n        if let Some((k, v)) = kv.split_once('=') {\n            if let Some(date_val) = Value::parse_as_date(v) {\n                fm.insert(k.to_string(), date_val);\n            } else {\n                fm.insert(k.to_string(), Value::String(v.to_string()));\n            }\n        }\n    }\n\n    let today = chrono::Local::now().date_naive();\n    fm.insert(\"created_at\".into(), Value::Date(today));\n    fm.insert(\"updated_at\".into(), Value::Date(today));\n\n    let entity = repo.create(fm, \"\", &config.registry)?;\n    println!(\"Created {} ({})\", entity.id, entity.entity_type);\n    if let Some(path) = &entity.file_path {\n        println!(\"  File: {}\", path.display());\n    }\n\n    Ok(())\n}\n```\n\nCreate `src/cli/show.rs`:\n\n```rust\nuse clap::Args;\nuse crate::config::Config;\nuse crate::error::Result;\nuse crate::storage::markdown::MarkdownRepository;\nuse crate::storage::Repository;\n\n#[derive(Args)]\npub struct ShowArgs {\n    /// Entity ID\n    pub id: String,\n}\n\npub fn run(args: &ShowArgs, config: &Config) -> Result<()> {\n    let repo = MarkdownRepository::new(config.vault_path.clone());\n    let entity = repo.get_by_id(&args.id, &config.registry)?;\n\n    println!(\"ID: {}\", entity.id);\n    println!(\"Type: {}\", entity.entity_type);\n    println!(\"Title: {}\", entity.title());\n\n    // Print all frontmatter fields\n    let mut keys: Vec<&String> = entity.frontmatter.keys().collect();\n    keys.sort();\n    for key in keys {\n        if key == \"id\" || key == \"type\" || key == \"title\" || key == \"name\" {\n            continue;\n        }\n        println!(\"  {key}: {}\", entity.frontmatter[key]);\n    }\n\n    if !entity.body.trim().is_empty() {\n        println!(\"\\n{}\", entity.body);\n    }\n\n    Ok(())\n}\n```\n\nCreate `src/cli/update.rs`:\n\n```rust\nuse clap::Args;\nuse crate::config::Config;\nuse crate::error::Result;\nuse crate::storage::markdown::MarkdownRepository;\nuse crate::storage::Repository;\nuse crate::value::Value;\nuse std::collections::HashMap;\n\n#[derive(Args)]\npub struct UpdateArgs {\n    /// Entity ID\n    pub id: String,\n\n    /// Field updates as key=value pairs\n    #[arg(long = \"set\", num_args = 1, required = true)]\n    pub updates: Vec<String>,\n}\n\npub fn run(args: &UpdateArgs, config: &Config) -> Result<()> {\n    let repo = MarkdownRepository::new(config.vault_path.clone());\n\n    let mut updates = HashMap::new();\n    for kv in &args.updates {\n        if let Some((k, v)) = kv.split_once('=') {\n            if let Some(date_val) = Value::parse_as_date(v) {\n                updates.insert(k.to_string(), date_val);\n            } else if v.starts_with('[') {\n                // Simple array parsing: [a,b,c]\n                let inner = v.trim_start_matches('[').trim_end_matches(']');\n                let arr: Vec<Value> = inner\n                    .split(',')\n                    .map(|s| Value::String(s.trim().trim_matches('\"').to_string()))\n                    .collect();\n                updates.insert(k.to_string(), Value::Array(arr));\n            } else {\n                updates.insert(k.to_string(), Value::String(v.to_string()));\n            }\n        }\n    }\n\n    let entity = repo.update(&args.id, updates, &config.registry)?;\n    println!(\"Updated {}\", entity.id);\n\n    Ok(())\n}\n```\n\nCreate `src/cli/archive.rs`:\n\n```rust\nuse clap::Args;\nuse crate::config::Config;\nuse crate::error::Result;\nuse crate::storage::markdown::MarkdownRepository;\nuse crate::storage::Repository;\nuse crate::value::Value;\nuse std::collections::HashMap;\n\n#[derive(Args)]\npub struct ArchiveArgs {\n    /// Entity ID\n    pub id: String,\n}\n\npub fn run(args: &ArchiveArgs, config: &Config) -> Result<()> {\n    let repo = MarkdownRepository::new(config.vault_path.clone());\n\n    let mut updates = HashMap::new();\n    updates.insert(\"status\".into(), Value::String(\"archived\".into()));\n\n    let entity = repo.update(&args.id, updates, &config.registry)?;\n    println!(\"Archived {}\", entity.id);\n\n    Ok(())\n}\n```\n\nCreate `src/cli/delete.rs`:\n\n```rust\nuse clap::Args;\nuse crate::config::Config;\nuse crate::error::Result;\nuse crate::storage::markdown::MarkdownRepository;\nuse crate::storage::Repository;\n\n#[derive(Args)]\npub struct DeleteArgs {\n    /// Entity ID\n    pub id: String,\n\n    /// Skip confirmation\n    #[arg(long)]\n    pub force: bool,\n}\n\npub fn run(args: &DeleteArgs, config: &Config) -> Result<()> {\n    let repo = MarkdownRepository::new(config.vault_path.clone());\n    repo.delete(&args.id, &config.registry)?;\n    println!(\"Deleted {}\", args.id);\n\n    Ok(())\n}\n```\n\nCreate `src/cli/query_cmd.rs`:\n\n```rust\nuse clap::Args;\nuse crate::config::Config;\nuse crate::error::Result;\nuse crate::query::evaluator::evaluate;\nuse crate::query::parser::parse_query;\nuse crate::storage::markdown::MarkdownRepository;\nuse crate::storage::Repository;\n\n#[derive(Args)]\npub struct QueryArgs {\n    /// Query expression\n    pub expression: String,\n\n    /// Output format (text or json)\n    #[arg(long, default_value = \"text\")]\n    pub format: String,\n}\n\npub fn run(args: &QueryArgs, config: &Config) -> Result<()> {\n    let expr = parse_query(&args.expression)?;\n    let repo = MarkdownRepository::new(config.vault_path.clone());\n    let all = repo.list_all(&config.registry)?;\n\n    let matches: Vec<_> = all.iter().filter(|e| evaluate(&expr, e)).collect();\n\n    if args.format == \"json\" {\n        let items: Vec<serde_json::Value> = matches\n            .iter()\n            .map(|e| {\n                let mut map = serde_json::Map::new();\n                for (k, v) in &e.frontmatter {\n                    map.insert(k.clone(), serde_json::Value::String(v.to_string()));\n                }\n                serde_json::Value::Object(map)\n            })\n            .collect();\n        println!(\"{}\", serde_json::to_string_pretty(&items).unwrap_or_default());\n    } else {\n        println!(\"Found {} results:\\n\", matches.len());\n        for entity in &matches {\n            println!(\"- [{}] {} ({})\", entity.entity_type, entity.title(), entity.id);\n            if let Some(status) = entity.get(\"status\") {\n                print!(\"  status: {status}\");\n            }\n            if let Some(due) = entity.get(\"due\") {\n                print!(\"  due: {due}\");\n            }\n            println!();\n        }\n    }\n\n    Ok(())\n}\n```\n\nCreate `src/cli/meta.rs`:\n\n```rust\nuse clap::{Args, Subcommand};\nuse crate::config::Config;\nuse crate::error::Result;\nuse crate::query::evaluator::evaluate;\nuse crate::query::parser::parse_query;\nuse crate::storage::markdown::MarkdownRepository;\nuse crate::storage::Repository;\nuse crate::value::Value;\nuse std::collections::HashMap;\n\n#[derive(Args)]\npub struct MetaArgs {\n    #[command(subcommand)]\n    pub command: MetaCommands,\n}\n\n#[derive(Subcommand)]\npub enum MetaCommands {\n    /// Get distinct values for a field\n    Distinct {\n        /// Field name\n        field: String,\n        /// Filter expression\n        #[arg(long = \"where\")]\n        filter: Option<String>,\n    },\n    /// Count entities grouped by a field\n    CountBy {\n        /// Field name\n        field: String,\n        /// Filter expression\n        #[arg(long = \"where\")]\n        filter: Option<String>,\n    },\n}\n\npub fn run(args: &MetaArgs, config: &Config) -> Result<()> {\n    let repo = MarkdownRepository::new(config.vault_path.clone());\n    let all = repo.list_all(&config.registry)?;\n\n    match &args.command {\n        MetaCommands::Distinct { field, filter } => {\n            let filtered = apply_filter(all, filter.as_deref())?;\n            let mut unique = std::collections::BTreeSet::new();\n\n            for entity in &filtered {\n                if let Some(val) = entity.get(field) {\n                    match val {\n                        Value::Array(items) => {\n                            for item in items {\n                                unique.insert(item.to_string());\n                            }\n                        }\n                        other => {\n                            unique.insert(other.to_string());\n                        }\n                    }\n                }\n            }\n\n            println!(\"Distinct values for '{field}' ({} values):\\n\", unique.len());\n            for v in &unique {\n                println!(\"  {v}\");\n            }\n        }\n        MetaCommands::CountBy { field, filter } => {\n            let filtered = apply_filter(all, filter.as_deref())?;\n            let mut counts: HashMap<String, usize> = HashMap::new();\n\n            for entity in &filtered {\n                if let Some(val) = entity.get(field) {\n                    match val {\n                        Value::Array(items) => {\n                            for item in items {\n                                *counts.entry(item.to_string()).or_default() += 1;\n                            }\n                        }\n                        other => {\n                            *counts.entry(other.to_string()).or_default() += 1;\n                        }\n                    }\n                }\n            }\n\n            // Sort by count descending\n            let mut sorted: Vec<_> = counts.into_iter().collect();\n            sorted.sort_by(|a, b| b.1.cmp(&a.1));\n\n            println!(\"Count by '{field}':\\n\");\n            for (val, count) in &sorted {\n                println!(\"  {val}: {count}\");\n            }\n        }\n    }\n\n    Ok(())\n}\n\nfn apply_filter(\n    entities: Vec<crate::entity::Entity>,\n    filter: Option<&str>,\n) -> Result<Vec<crate::entity::Entity>> {\n    match filter {\n        Some(expr_str) => {\n            let expr = parse_query(expr_str)?;\n            Ok(entities.into_iter().filter(|e| evaluate(&expr, e)).collect())\n        }\n        None => Ok(entities),\n    }\n}\n```\n\nCreate `src/cli/task.rs`:\n\n```rust\nuse clap::{Args, Subcommand};\nuse crate::config::Config;\nuse crate::error::Result;\nuse crate::query::evaluator::evaluate;\nuse crate::query::parser::parse_query;\nuse crate::storage::markdown::MarkdownRepository;\nuse crate::storage::Repository;\nuse crate::value::Value;\nuse std::collections::HashMap;\n\n#[derive(Args)]\npub struct TaskArgs {\n    #[command(subcommand)]\n    pub command: TaskCommands,\n}\n\n#[derive(Subcommand)]\npub enum TaskCommands {\n    /// List inbox tasks (open, no project)\n    Inbox,\n    /// List next actions (open, scheduled <= today)\n    Next,\n    /// List overdue tasks (not done, due < today)\n    Overdue,\n    /// Claim a task\n    Claim {\n        /// Task ID\n        id: String,\n        /// Assignee (person ID)\n        #[arg(long)]\n        assignee: String,\n    },\n    /// Mark a task as complete\n    Complete {\n        /// Task ID\n        id: String,\n    },\n}\n\npub fn run(args: &TaskArgs, config: &Config) -> Result<()> {\n    let repo = MarkdownRepository::new(config.vault_path.clone());\n\n    match &args.command {\n        TaskCommands::Inbox => {\n            let tasks = repo.list_by_type(\"task\", &config.registry)?;\n            let inbox: Vec<_> = tasks\n                .iter()\n                .filter(|t| {\n                    t.get(\"status\").is_some_and(|s| s == &Value::String(\"open\".into()))\n                        && t.get(\"project\").is_none()\n                })\n                .collect();\n\n            println!(\"Inbox ({} tasks):\\n\", inbox.len());\n            for t in &inbox {\n                println!(\"- {} ({})\", t.title(), t.id);\n            }\n        }\n        TaskCommands::Next => {\n            let today = chrono::Local::now().date_naive();\n            let expr = parse_query(r#\"type = \"task\" and status = \"open\"\"#)?;\n            let all = repo.list_all(&config.registry)?;\n            let mut next: Vec<_> = all\n                .iter()\n                .filter(|e| {\n                    evaluate(&expr, e)\n                        && e.get(\"scheduled\")\n                            .and_then(|v| v.as_date())\n                            .is_none_or(|d| d <= today)\n                })\n                .collect();\n\n            // Sort by due date\n            next.sort_by(|a, b| {\n                let da = a.get(\"due\").and_then(|v| v.as_date());\n                let db = b.get(\"due\").and_then(|v| v.as_date());\n                da.cmp(&db)\n            });\n\n            println!(\"Next actions ({} tasks):\\n\", next.len());\n            for t in &next {\n                let due_str = t\n                    .get(\"due\")\n                    .map(|v| v.to_string())\n                    .unwrap_or_else(|| \"no due date\".into());\n                println!(\"- {} ({}) — due: {due_str}\", t.title(), t.id);\n            }\n        }\n        TaskCommands::Overdue => {\n            let today = chrono::Local::now().date_naive();\n            let tasks = repo.list_by_type(\"task\", &config.registry)?;\n            let overdue: Vec<_> = tasks\n                .iter()\n                .filter(|t| {\n                    let not_done = t\n                        .get(\"status\")\n                        .is_some_and(|s| s != &Value::String(\"done\".into()) && s != &Value::String(\"cancelled\".into()));\n                    let past_due = t\n                        .get(\"due\")\n                        .and_then(|v| v.as_date())\n                        .is_some_and(|d| d < today);\n                    not_done && past_due\n                })\n                .collect();\n\n            println!(\"Overdue ({} tasks):\\n\", overdue.len());\n            for t in &overdue {\n                let due = t.get(\"due\").map(|v| v.to_string()).unwrap_or_default();\n                println!(\"- {} ({}) — due: {due}\", t.title(), t.id);\n            }\n        }\n        TaskCommands::Claim { id, assignee } => {\n            let mut updates = HashMap::new();\n            updates.insert(\"assignee\".into(), Value::String(format!(\"[[{assignee}]]\")));\n            updates.insert(\"status\".into(), Value::String(\"in_progress\".into()));\n            repo.update(id, updates, &config.registry)?;\n            println!(\"Claimed {id} by {assignee}\");\n        }\n        TaskCommands::Complete { id } => {\n            let mut updates = HashMap::new();\n            updates.insert(\"status\".into(), Value::String(\"done\".into()));\n            repo.update(id, updates, &config.registry)?;\n            println!(\"Completed {id}\");\n        }\n    }\n\n    Ok(())\n}\n```\n\nCreate `src/cli/person.rs`:\n\n```rust\nuse clap::{Args, Subcommand};\nuse crate::config::Config;\nuse crate::error::Result;\nuse crate::storage::markdown::MarkdownRepository;\nuse crate::storage::Repository;\n\n#[derive(Args)]\npub struct PersonArgs {\n    #[command(subcommand)]\n    pub command: PersonCommands,\n}\n\n#[derive(Subcommand)]\npub enum PersonCommands {\n    /// List all people\n    List {\n        /// Filter by tag\n        #[arg(long)]\n        tag: Option<String>,\n    },\n    /// Show timeline for a person (references across vault)\n    Timeline {\n        /// Person ID\n        id: String,\n    },\n}\n\npub fn run(args: &PersonArgs, config: &Config) -> Result<()> {\n    let repo = MarkdownRepository::new(config.vault_path.clone());\n\n    match &args.command {\n        PersonCommands::List { tag } => {\n            let people = repo.list_by_type(\"person\", &config.registry)?;\n            let filtered: Vec<_> = if let Some(tag) = tag {\n                let tag_val = crate::value::Value::String(tag.clone());\n                people\n                    .iter()\n                    .filter(|p| p.get(\"tags\").is_some_and(|t| t.contains(&tag_val)))\n                    .collect()\n            } else {\n                people.iter().collect()\n            };\n\n            println!(\"People ({}):\\n\", filtered.len());\n            for p in &filtered {\n                let name = p\n                    .get(\"name\")\n                    .map(|v| v.to_string())\n                    .unwrap_or_else(|| p.id.clone());\n                println!(\"- {name} ({})\", p.id);\n            }\n        }\n        PersonCommands::Timeline { id } => {\n            let all = repo.list_all(&config.registry)?;\n            let pattern = format!(\"[[{id}]]\");\n            let refs: Vec<_> = all\n                .iter()\n                .filter(|e| {\n                    e.id != *id\n                        && (e.frontmatter.values().any(|v| {\n                            v.as_str().is_some_and(|s| s.contains(&pattern))\n                        }) || e.body.contains(&pattern))\n                })\n                .collect();\n\n            println!(\"Timeline for {id} ({} references):\\n\", refs.len());\n            for e in &refs {\n                println!(\"- [{}] {} ({})\", e.entity_type, e.title(), e.id);\n            }\n        }\n    }\n\n    Ok(())\n}\n```\n\nCreate `src/cli/company.rs`:\n\n```rust\nuse clap::{Args, Subcommand};\nuse crate::config::Config;\nuse crate::error::Result;\nuse crate::storage::markdown::MarkdownRepository;\nuse crate::storage::Repository;\n\n#[derive(Args)]\npub struct CompanyArgs {\n    #[command(subcommand)]\n    pub command: CompanyCommands,\n}\n\n#[derive(Subcommand)]\npub enum CompanyCommands {\n    /// List people at a company\n    People {\n        /// Company ID\n        id: String,\n    },\n}\n\npub fn run(args: &CompanyArgs, config: &Config) -> Result<()> {\n    let repo = MarkdownRepository::new(config.vault_path.clone());\n\n    match &args.command {\n        CompanyCommands::People { id } => {\n            let people = repo.list_by_type(\"person\", &config.registry)?;\n            let pattern = format!(\"[[{id}]]\");\n            let at_company: Vec<_> = people\n                .iter()\n                .filter(|p| {\n                    p.get(\"company\")\n                        .and_then(|v| v.as_str())\n                        .is_some_and(|s| s == pattern)\n                })\n                .collect();\n\n            println!(\"People at {id} ({}):\\n\", at_company.len());\n            for p in &at_company {\n                let name = p.get(\"name\").map(|v| v.to_string()).unwrap_or_default();\n                println!(\"- {name} ({})\", p.id);\n            }\n        }\n    }\n\n    Ok(())\n}\n```\n\nCreate `src/cli/note.rs`:\n\n```rust\nuse clap::{Args, Subcommand};\nuse crate::config::Config;\nuse crate::error::{CortxError, Result};\nuse crate::storage::markdown::MarkdownRepository;\nuse crate::storage::Repository;\n\n#[derive(Args)]\npub struct NoteArgs {\n    #[command(subcommand)]\n    pub command: NoteCommands,\n}\n\n#[derive(Subcommand)]\npub enum NoteCommands {\n    /// List headings in a note\n    Headings {\n        /// Entity ID\n        id: String,\n    },\n    /// Insert content after a heading\n    InsertAfterHeading {\n        /// Entity ID\n        id: String,\n        /// Heading text (e.g., \"## Action items\")\n        #[arg(long)]\n        heading: String,\n        /// Content to insert\n        #[arg(long)]\n        content: String,\n    },\n    /// Replace a named block\n    ReplaceBlock {\n        /// Entity ID\n        id: String,\n        /// Block ID\n        #[arg(long = \"block-id\")]\n        block_id: String,\n        /// New content\n        #[arg(long)]\n        content: String,\n    },\n    /// Read specific lines\n    ReadLines {\n        /// Entity ID\n        id: String,\n        /// Start line (1-based)\n        #[arg(long)]\n        start: usize,\n        /// End line (1-based, inclusive)\n        #[arg(long)]\n        end: usize,\n    },\n}\n\npub fn run(args: &NoteArgs, config: &Config) -> Result<()> {\n    let repo = MarkdownRepository::new(config.vault_path.clone());\n\n    match &args.command {\n        NoteCommands::Headings { id } => {\n            let entity = repo.get_by_id(id, &config.registry)?;\n            let headings = extract_headings(&entity.body);\n            println!(\"Headings in {id}:\\n\");\n            for (line_num, heading) in &headings {\n                println!(\"  Line {line_num}: {heading}\");\n            }\n        }\n        NoteCommands::InsertAfterHeading {\n            id,\n            heading,\n            content,\n        } => {\n            let entity = repo.get_by_id(id, &config.registry)?;\n            let new_body = insert_after_heading(&entity.body, heading, content)?;\n\n            let path = entity\n                .file_path\n                .as_ref()\n                .ok_or_else(|| CortxError::Storage(\"no file path\".into()))?;\n            let file_content =\n                crate::frontmatter::serialize_entity(&entity.frontmatter, &new_body);\n            std::fs::write(path, file_content)?;\n            println!(\"Inserted content after '{heading}' in {id}\");\n        }\n        NoteCommands::ReplaceBlock {\n            id,\n            block_id,\n            content,\n        } => {\n            let entity = repo.get_by_id(id, &config.registry)?;\n            let new_body = replace_block(&entity.body, block_id, content)?;\n\n            let path = entity\n                .file_path\n                .as_ref()\n                .ok_or_else(|| CortxError::Storage(\"no file path\".into()))?;\n            let file_content =\n                crate::frontmatter::serialize_entity(&entity.frontmatter, &new_body);\n            std::fs::write(path, file_content)?;\n            println!(\"Replaced block '{block_id}' in {id}\");\n        }\n        NoteCommands::ReadLines { id, start, end } => {\n            let entity = repo.get_by_id(id, &config.registry)?;\n            let lines: Vec<&str> = entity.body.lines().collect();\n            let start_idx = start.saturating_sub(1);\n            let end_idx = (*end).min(lines.len());\n            for (i, line) in lines[start_idx..end_idx].iter().enumerate() {\n                println!(\"{:4}: {line}\", start_idx + i + 1);\n            }\n        }\n    }\n\n    Ok(())\n}\n\nfn extract_headings(body: &str) -> Vec<(usize, String)> {\n    body.lines()\n        .enumerate()\n        .filter_map(|(i, line)| {\n            if line.starts_with('#') {\n                Some((i + 1, line.to_string()))\n            } else {\n                None\n            }\n        })\n        .collect()\n}\n\nfn insert_after_heading(body: &str, heading: &str, content: &str) -> Result<String> {\n    let lines: Vec<&str> = body.lines().collect();\n    let heading_idx = lines\n        .iter()\n        .position(|line| line.trim() == heading.trim())\n        .ok_or_else(|| {\n            CortxError::Storage(format!(\"heading '{heading}' not found\"))\n        })?;\n\n    let mut result = Vec::new();\n    for (i, line) in lines.iter().enumerate() {\n        result.push(*line);\n        if i == heading_idx {\n            result.push(content);\n        }\n    }\n\n    Ok(result.join(\"\\n\") + \"\\n\")\n}\n\nfn replace_block(body: &str, block_id: &str, content: &str) -> Result<String> {\n    let open_tag = format!(\"<!-- block:id={block_id} -->\");\n    let close_tag = format!(\"<!-- /block:id={block_id} -->\");\n\n    let open_pos = body\n        .find(&open_tag)\n        .ok_or_else(|| CortxError::Storage(format!(\"block '{block_id}' not found\")))?;\n    let close_pos = body\n        .find(&close_tag)\n        .ok_or_else(|| CortxError::Storage(format!(\"closing tag for block '{block_id}' not found\")))?;\n\n    let before = &body[..open_pos + open_tag.len()];\n    let after = &body[close_pos..];\n\n    Ok(format!(\"{before}\\n{content}\\n{after}\"))\n}\n```\n\nCreate `src/cli/doctor.rs`:\n\n```rust\nuse clap::{Args, Subcommand};\nuse crate::config::Config;\nuse crate::error::Result;\nuse crate::schema::validation::validate_frontmatter;\nuse crate::storage::markdown::MarkdownRepository;\nuse crate::storage::Repository;\nuse regex::Regex;\n\n#[derive(Args)]\npub struct DoctorArgs {\n    #[command(subcommand)]\n    pub command: DoctorCommands,\n}\n\n#[derive(Subcommand)]\npub enum DoctorCommands {\n    /// Validate all files against schemas\n    Validate,\n    /// Check for broken links\n    Links,\n}\n\npub fn run(args: &DoctorArgs, config: &Config) -> Result<()> {\n    let repo = MarkdownRepository::new(config.vault_path.clone());\n\n    match &args.command {\n        DoctorCommands::Validate => {\n            let all = repo.list_all(&config.registry)?;\n            let mut errors = 0;\n\n            for entity in &all {\n                if let Some(type_def) = config.registry.get(&entity.entity_type) {\n                    if let Err(e) = validate_frontmatter(&entity.frontmatter, type_def) {\n                        errors += 1;\n                        println!(\"ERROR in {} ({}): {e}\", entity.id, entity.entity_type);\n                    }\n                }\n            }\n\n            if errors == 0 {\n                println!(\"All {} entities pass validation.\", all.len());\n            } else {\n                println!(\"\\n{errors} validation error(s) found in {} entities.\", all.len());\n            }\n        }\n        DoctorCommands::Links => {\n            let all = repo.list_all(&config.registry)?;\n            let all_ids: std::collections::HashSet<String> =\n                all.iter().map(|e| e.id.clone()).collect();\n\n            let link_re = Regex::new(r\"\\[