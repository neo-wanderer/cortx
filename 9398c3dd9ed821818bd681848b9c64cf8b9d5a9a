            "new_string": "---\n\n### Task 8: File locking for concurrent writes\n\n**Files:**\n- Create: `src/storage/file_lock.rs`\n- Modify: `src/storage/mod.rs`\n- Modify: `src/storage/markdown.rs`\n- Modify: `tests/storage_test.rs` (append)\n\nSince the CLI is invoked as a separate process per agent command, in-memory locks don't work across invocations. We use filesystem-based `.lock` files with atomic creation (`O_CREAT | O_EXCL`) to prevent two processes from writing the same entity simultaneously. Writes to *different* files remain fully parallel with no contention.\n\n- [ ] **Step 1: Write failing tests for file locking**\n\nAppend to `tests/storage_test.rs`:\n\n```rust\nuse cortx::storage::file_lock::FileLock;\nuse std::path::PathBuf;\n\n#[test]\nfn test_file_lock_acquire_and_release() {\n    let vault = TestVault::new();\n    let lock_path = vault.path().join(\"test.md\");\n    // Create a dummy file to lock\n    std::fs::write(&lock_path, \"test\").unwrap();\n\n    let lock = FileLock::acquire(&lock_path).unwrap();\n    assert!(vault.path().join(\"test.md.lock\").exists());\n\n    lock.release().unwrap();\n    assert!(!vault.path().join(\"test.md.lock\").exists());\n}\n\n#[test]\nfn test_file_lock_contention() {\n    let vault = TestVault::new();\n    let lock_path = vault.path().join(\"test.md\");\n    std::fs::write(&lock_path, \"test\").unwrap();\n\n    let lock1 = FileLock::acquire(&lock_path).unwrap();\n\n    // Second lock attempt on same file should fail\n    let lock2 = FileLock::acquire(&lock_path);\n    assert!(lock2.is_err());\n    let err = lock2.unwrap_err().to_string();\n    assert!(err.contains(\"locked\"), \"error should mention lock: {err}\");\n\n    lock1.release().unwrap();\n\n    // Now it should succeed\n    let lock3 = FileLock::acquire(&lock_path).unwrap();\n    lock3.release().unwrap();\n}\n\n#[test]\nfn test_file_lock_drop_releases() {\n    let vault = TestVault::new();\n    let lock_path = vault.path().join(\"test.md\");\n    std::fs::write(&lock_path, \"test\").unwrap();\n\n    {\n        let _lock = FileLock::acquire(&lock_path).unwrap();\n        assert!(vault.path().join(\"test.md.lock\").exists());\n    }\n    // Drop should have released\n    assert!(!vault.path().join(\"test.md.lock\").exists());\n}\n\n#[test]\nfn test_update_with_locking() {\n    let vault = TestVault::new();\n    let registry = test_registry();\n    let repo = MarkdownRepository::new(vault.path().to_path_buf());\n\n    vault.write_file(\n        \"1_Projects/tasks/task-lock.md\",\n        \"---\\nid: task-lock\\ntype: task\\ntitle: Lock test\\nstatus: open\\ntags: []\\n---\\n\",\n    );\n\n    let mut updates = HashMap::new();\n    updates.insert(\"status\".into(), Value::String(\"done\".into()));\n\n    // Update acquires and releases lock internally\n    let entity = repo.update(\"task-lock\", updates, &registry).unwrap();\n    assert_eq!(entity.get(\"status\").unwrap(), &Value::String(\"done\".into()));\n\n    // Lock file should not linger\n    assert!(!vault.file_exists(\"1_Projects/tasks/task-lock.md.lock\"));\n}\n```\n\n- [ ] **Step 2: Run tests to verify they fail**\n\nRun: `cargo test --test storage_test -- test_file_lock`\nExpected: FAIL — `file_lock` module not found.\n\n- [ ] **Step 3: Implement FileLock**\n\nCreate `src/storage/file_lock.rs`:\n\n```rust\nuse std::fs::{self, File, OpenOptions};\nuse std::path::{Path, PathBuf};\nuse crate::error::{CortxError, Result};\n\n/// A filesystem-based advisory lock for a single file.\n///\n/// Creates a `{file}.lock` file using atomic `O_CREAT | O_EXCL` to ensure\n/// only one process can hold the lock at a time. The lock is released\n/// on `release()` or automatically when dropped.\n///\n/// # Examples\n///\n/// ```no_run\n/// use cortx::storage::file_lock::FileLock;\n/// use std::path::Path;\n///\n/// let lock = FileLock::acquire(Path::new(\"entity.md\")).unwrap();\n/// // ... perform write ...\n/// lock.release().unwrap();\n/// ```\npub struct FileLock {\n    lock_path: PathBuf,\n    released: bool,\n}\n\nimpl FileLock {\n    /// Acquire a lock for the given file path.\n    ///\n    /// Creates `{path}.lock`. Fails immediately if the lock file already exists\n    /// (another process holds the lock).\n    pub fn acquire(file_path: &Path) -> Result<Self> {\n        let lock_path = lock_path_for(file_path);\n\n        // O_CREAT | O_EXCL: atomic create-or-fail\n        match OpenOptions::new()\n            .write(true)\n            .create_new(true)\n            .open(&lock_path)\n        {\n            Ok(_file) => Ok(FileLock {\n                lock_path,\n                released: false,\n            }),\n            Err(e) if e.kind() == std::io::ErrorKind::AlreadyExists => {\n                Err(CortxError::Storage(format!(\n                    \"entity is locked by another process ({})\",\n                    lock_path.display()\n                )))\n            }\n            Err(e) => Err(CortxError::Io(e)),\n        }\n    }\n\n    /// Release the lock by removing the lock file.\n    pub fn release(mut self) -> Result<()> {\n        self.do_release()\n    }\n\n    fn do_release(&mut self) -> Result<()> {\n        if !self.released {\n            self.released = true;\n            if self.lock_path.exists() {\n                fs::remove_file(&self.lock_path)?;\n            }\n        }\n        Ok(())\n    }\n}\n\nimpl Drop for FileLock {\n    fn drop(&mut self) {\n        // Best-effort release on drop\n        let _ = self.do_release();\n    }\n}\n\nfn lock_path_for(file_path: &Path) -> PathBuf {\n    let mut lock = file_path.as_os_str().to_owned();\n    lock.push(\".lock\");\n    PathBuf::from(lock)\n}\n```\n\n- [ ] **Step 4: Add `file_lock` to storage module**\n\nAdd to `src/storage/mod.rs`:\n\n```rust\npub mod file_lock;\npub mod markdown;\n```\n\n- [ ] **Step 5: Integrate locking into MarkdownRepository::update and delete**\n\nIn `src/storage/markdown.rs`, modify the `update` method to acquire a lock before reading, and release after writing:\n\n```rust\n    fn update(\n        &self,\n        id: &str,\n        updates: HashMap<String, Value>,\n        registry: &TypeRegistry,\n    ) -> Result<Entity> {\n        let path = self.find_file_by_id(id, registry)?;\n\n        // Acquire file lock\n        let lock = file_lock::FileLock::acquire(&path)?;\n\n        let mut entity = self.read_entity(&path)?;\n\n        // Merge updates into existing frontmatter\n        for (key, val) in updates {\n            entity.frontmatter.insert(key, val);\n        }\n\n        // Update updated_at\n        let today = chrono::Local::now().date_naive();\n        entity\n            .frontmatter\n            .insert(\"updated_at\".into(), Value::Date(today));\n\n        // Validate merged frontmatter\n        if let Some(type_def) = registry.get(&entity.entity_type) {\n            validate_frontmatter(&entity.frontmatter, type_def)?;\n        }\n\n        let content = serialize_entity(&entity.frontmatter, &entity.body);\n        std::fs::write(&path, content)?;\n\n        // Release lock\n        lock.release()?;\n\n        entity.file_path = Some(path);\n        Ok(entity)\n    }\n\n    fn delete(&self, id: &str, registry: &TypeRegistry) -> Result<()> {\n        let path = self.find_file_by_id(id, registry)?;\n\n        // Acquire file lock\n        let lock = file_lock::FileLock::acquire(&path)?;\n\n        std::fs::remove_file(&path)?;\n\n        // Release lock (lock file cleanup)\n        lock.release()?;\n\n        Ok(())\n    }\n```\n\n- [ ] **Step 6: Run tests to verify they pass**\n\nRun: `cargo test --test storage_test`\nExpected: All storage tests pass, including the 4 new locking tests.\n\n- [ ] **Step 7: Commit**\n\n```bash\ngit add src/storage/file_lock.rs src/storage/mod.rs src/storage/markdown.rs tests/storage_test.rs\ngit commit -m \"feat: add file-level locking for safe concurrent writes\"\n```\n\n---\n\n## Phase 3: Query Engine\n\n### Task 9: Query AST types",
