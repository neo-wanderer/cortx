            "new_string": "- [ ] **Step 5: Commit any final fixes**\n\n```bash\ngit add -A\ngit commit -m \"chore: final cleanup and verification\"\n```\n\n---\n\n### Task 15: Performance benchmarks\n\n**Files:**\n- Modify: `Cargo.toml` (add criterion dev-dependency)\n- Create: `benches/query_bench.rs`\n\nThe spec (conversation.md) identifies performance thresholds: <50ms at 500 files, 100-500ms at 1k-5k, 1-3s at 10k. This task establishes benchmarks so we can measure where we stand and catch regressions as the codebase evolves.\n\n- [ ] **Step 1: Add criterion dependency**\n\nAdd to `Cargo.toml`:\n\n```toml\n[dev-dependencies]\ntempfile = \"3\"\nassert_cmd = \"2\"\npredicates = \"3\"\ncriterion = { version = \"0.5\", features = [\"html_reports\"] }\n\n[[bench]]\nname = \"query_bench\"\nharness = false\n```\n\n- [ ] **Step 2: Write the benchmark**\n\nCreate `benches/query_bench.rs`:\n\n```rust\nuse criterion::{criterion_group, criterion_main, BenchmarkId, Criterion};\nuse std::collections::HashMap;\nuse std::fs;\nuse std::path::Path;\nuse tempfile::TempDir;\n\nuse cortx::entity::Entity;\nuse cortx::frontmatter::serialize_entity;\nuse cortx::query::evaluator::evaluate;\nuse cortx::query::parser::parse_query;\nuse cortx::schema::registry::TypeRegistry;\nuse cortx::storage::markdown::MarkdownRepository;\nuse cortx::storage::Repository;\nuse cortx::value::Value;\n\n/// Generate a vault with N task files spread across statuses and tags.\nfn generate_vault(dir: &Path, n: usize, registry: &TypeRegistry) {\n    let task_folder = dir.join(\"1_Projects/tasks\");\n    fs::create_dir_all(&task_folder).unwrap();\n\n    // Copy types.yaml\n    fs::copy(\"types.yaml\", dir.join(\"types.yaml\")).unwrap();\n\n    // Create other required folders\n    for folder in &[\"0_Inbox\", \"2_Areas\", \"3_Resources\", \"3_Resources/notes\",\n                     \"4_Archive\", \"5_People\", \"5_Companies\"] {\n        fs::create_dir_all(dir.join(folder)).unwrap();\n    }\n\n    let statuses = [\"open\", \"in_progress\", \"waiting\", \"done\"];\n    let all_tags = [\"home\", \"work\", \"urgent\", \"backend\", \"frontend\", \"api\", \"docs\"];\n\n    for i in 0..n {\n        let id = format!(\"task-bench-{i:06}\");\n        let status = statuses[i % statuses.len()];\n        let tag1 = all_tags[i % all_tags.len()];\n        let tag2 = all_tags[(i + 3) % all_tags.len()];\n\n        // Vary due dates: some past, some future\n        let day = (i % 28) + 1;\n        let month = if i % 2 == 0 { \"03\" } else { \"05\" };\n        let due = format!(\"2026-{month}-{day:02}\");\n\n        let mut fm = HashMap::new();\n        fm.insert(\"id\".into(), Value::String(id.clone()));\n        fm.insert(\"type\".into(), Value::String(\"task\".into()));\n        fm.insert(\"title\".into(), Value::String(format!(\"Benchmark task {i}\")));\n        fm.insert(\"status\".into(), Value::String(status.into()));\n        fm.insert(\"due\".into(), Value::parse_as_date(&due).unwrap());\n        fm.insert(\"tags\".into(), Value::Array(vec![\n            Value::String(tag1.into()),\n            Value::String(tag2.into()),\n        ]));\n        fm.insert(\"created_at\".into(), Value::parse_as_date(\"2026-01-01\").unwrap());\n        fm.insert(\"updated_at\".into(), Value::parse_as_date(\"2026-04-01\").unwrap());\n\n        let body = format!(\"# Task {i}\\n\\nThis is benchmark task number {i}.\\nIt contains some body text for search purposes.\\n\");\n        let content = serialize_entity(&fm, &body);\n        fs::write(task_folder.join(format!(\"{id}.md\")), content).unwrap();\n    }\n}\n\nfn bench_query_scan(c: &mut Criterion) {\n    let registry = TypeRegistry::from_yaml_file(Path::new(\"types.yaml\")).unwrap();\n\n    let mut group = c.benchmark_group(\"query_scan\");\n    group.sample_size(10);\n\n    for size in [100, 500, 1000, 5000] {\n        let dir = TempDir::new().unwrap();\n        generate_vault(dir.path(), size, &registry);\n        let repo = MarkdownRepository::new(dir.path().to_path_buf());\n\n        // Benchmark: list all tasks (full scan + frontmatter parse)\n        group.bench_with_input(\n            BenchmarkId::new(\"list_all\", size),\n            &size,\n            |b, _| {\n                b.iter(|| {\n                    let entities = repo.list_all(&registry).unwrap();\n                    assert_eq!(entities.len(), size);\n                });\n            },\n        );\n\n        // Benchmark: simple equality filter\n        let simple_expr = parse_query(r#\"type = \"task\" and status = \"open\"\"#).unwrap();\n        group.bench_with_input(\n            BenchmarkId::new(\"filter_simple\", size),\n            &size,\n            |b, _| {\n                b.iter(|| {\n                    let all = repo.list_all(&registry).unwrap();\n                    let matches: Vec<_> = all.iter().filter(|e| evaluate(&simple_expr, e)).collect();\n                    assert!(!matches.is_empty());\n                });\n            },\n        );\n\n        // Benchmark: complex filter (status + date + tags)\n        let complex_expr = parse_query(\n            r#\"type = \"task\" and status != \"done\" and due < \"2026-04-01\" and tags contains \"home\"\"#,\n        ).unwrap();\n        group.bench_with_input(\n            BenchmarkId::new(\"filter_complex\", size),\n            &size,\n            |b, _| {\n                b.iter(|| {\n                    let all = repo.list_all(&registry).unwrap();\n                    let _matches: Vec<_> = all.iter().filter(|e| evaluate(&complex_expr, e)).collect();\n                });\n            },\n        );\n\n        // Benchmark: text body search\n        let text_expr = parse_query(r#\"type = \"task\" and text ~ \"benchmark task\"\"#).unwrap();\n        group.bench_with_input(\n            BenchmarkId::new(\"filter_text_search\", size),\n            &size,\n            |b, _| {\n                b.iter(|| {\n                    let all = repo.list_all(&registry).unwrap();\n                    let matches: Vec<_> = all.iter().filter(|e| evaluate(&text_expr, e)).collect();\n                    assert!(!matches.is_empty());\n                });\n            },\n        );\n\n        // Benchmark: aggregation (distinct tags)\n        group.bench_with_input(\n            BenchmarkId::new(\"distinct_tags\", size),\n            &size,\n            |b, _| {\n                b.iter(|| {\n                    let all = repo.list_all(&registry).unwrap();\n                    let mut unique = std::collections::BTreeSet::new();\n                    for entity in &all {\n                        if let Some(Value::Array(tags)) = entity.get(\"tags\") {\n                            for tag in tags {\n                                unique.insert(tag.to_string());\n                            }\n                        }\n                    }\n                    assert!(!unique.is_empty());\n                });\n            },\n        );\n    }\n\n    group.finish();\n}\n\ncriterion_group!(benches, bench_query_scan);\ncriterion_main!(benches);\n```\n\n- [ ] **Step 3: Run benchmarks**\n\nRun: `cargo bench`\n\nExpected output looks like:\n\n```\nquery_scan/list_all/100     time:   [X.XX ms Y.YY ms Z.ZZ ms]\nquery_scan/list_all/500     time:   [X.XX ms Y.YY ms Z.ZZ ms]\nquery_scan/list_all/1000    time:   [X.XX ms Y.YY ms Z.ZZ ms]\nquery_scan/list_all/5000    time:   [X.XX ms Y.YY ms Z.ZZ ms]\nquery_scan/filter_simple/100  ...\nquery_scan/filter_complex/100 ...\nquery_scan/filter_text_search/100 ...\nquery_scan/distinct_tags/100 ...\n```\n\nRecord the baseline numbers. The spec targets:\n- 100-500 files: < 50ms\n- 1,000 files: < 500ms\n- 5,000 files: < 1-3s\n\n- [ ] **Step 4: Commit**\n\n```bash\ngit add Cargo.toml benches/query_bench.rs\ngit commit -m \"feat: add performance benchmarks with criterion\"\n```\n\n---\n\n## Summary",
